# pnpm configuration for Treeherder

# Equivalent to yarn's ignore-engines - don't check engine compatibility
engine-strict=false

# Save exact versions instead of ranges when adding packages
save-exact=true

# Don't run lifecycle scripts during install for security
ignore-scripts=true

# Hoist all dependencies to node_modules root for compatibility
# This makes pnpm behavior similar to npm/yarn flat node_modules
shamefully-hoist=true

# Auto-install peers to avoid peer dependency warnings
auto-install-peers=true

# Install native bindings for both macOS (local dev) and Linux (Docker container).
# Without this, pnpm only resolves bindings for the host platform in the lockfile,
# which breaks the frontend Docker container (linux-x64-musl).
supportedArchitectures.os[]=current
supportedArchitectures.os[]=linux
supportedArchitectures.cpu[]=current
supportedArchitectures.cpu[]=x64
supportedArchitectures.libc[]=current
supportedArchitectures.libc[]=musl
